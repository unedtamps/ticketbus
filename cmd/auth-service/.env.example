# Auth Service
APP_ENV=dev
PORT=8081
DATABASE_URL=postgres://ticketsaas:ticketsaas@localhost:5432/auth_db?sslmode=disable
JWT_PRIVATE_KEY=<required - openssl genrsa 2048 | base64 -w0>
JWT_PUBLIC_KEY=<required - openssl rsa -pubout < /dev/stdin | base64 -w0>
EVENT_SERVICE_URL=http://localhost:8082
SEED_ADMIN=true
ADMIN_EMAILS=admin@example.com
ADMIN_PASSWORDS=secure123
